{
  "name": "conclave-mr-web",
  "version": "2.0.0",
  "private": true,
  "description": "Pontuação Conclave — aplicacao web estatica de pontuacao do Conclave.",
  "scripts": {
    "lint": "eslint \"web/**/*.js\" \"tests/**/*.js\"",
    "test": "node --test",
    "format": "prettier --write \"**/*.{js,mjs,json,css,html,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,json,css,html,md,yml,yaml}\"",
    "build:embedded": "node scripts/build-embedded.mjs",
    "serve": "python3 -m http.server 8765 --bind 127.0.0.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0"
  }
}
