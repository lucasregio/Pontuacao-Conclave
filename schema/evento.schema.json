{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conclave-mr.local/evento.schema.json",
  "title": "Configuração de evento Pontuação Conclave",
  "type": "object",
  "required": ["meta", "pesos", "medalhas", "igrejas", "provas"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["nome", "slug"],
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "minimum": 1,
          "description": "Versão da estrutura de dados. Eventos sem este campo são tratados como versão 1 e migrados em memória. A versão atual é 2."
        },
        "nome": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "data": { "type": "string", "description": "ISO date ou texto livre" },
        "local": {
          "type": "string",
          "description": "Local do evento (exibido na capa do relatório oficial)"
        },
        "horarioInicio": { "type": "string", "description": "HH:MM (input time)" },
        "horarioEncerramento": { "type": "string", "description": "HH:MM (input time)" },
        "regulamentoUrl": { "type": "string" },
        "regulamentoNome": {
          "type": "string",
          "description": "Nome do arquivo PDF carregado pelo organizador (exibição na UI; opcional)."
        },
        "tema": {
          "type": "object",
          "properties": {
            "backgroundImage": {
              "type": "string",
              "deprecated": true,
              "description": "Campo legado: aceito em importações antigas mas ignorado pela UI."
            },
            "accentColor": {
              "type": "string",
              "deprecated": true,
              "description": "Campo legado: aceito mas não consumido pela UI. Será removido em uma futura versão do schema."
            }
          }
        }
      }
    },
    "pesos": {
      "type": "object",
      "required": [
        "inscricao",
        "pontualidade",
        "uniforme",
        "biblia",
        "visitante",
        "animacao",
        "mau_comportamento"
      ],
      "properties": {
        "inscricao": { "type": "number" },
        "pontualidade": { "type": "number" },
        "uniforme": { "type": "number" },
        "biblia": { "type": "number" },
        "visitante": { "type": "number" },
        "animacao": { "type": "number" },
        "mau_comportamento": { "type": "number" }
      }
    },
    "categorias": {
      "type": "array",
      "description": "Categorias de provas (Junior, Adolescente, …); ordem define colunas no pódio",
      "items": {
        "type": "object",
        "required": ["id", "nome", "ordem"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "nome": { "type": "string", "minLength": 1 },
          "ordem": { "type": "integer", "minimum": 0 },
          "idade": {
            "type": "string",
            "description": "Faixa etária livre exibida ao lado do nome da categoria (opcional)."
          }
        }
      }
    },
    "medalhas": {
      "type": "object",
      "required": ["ou", "pt", "br"],
      "properties": {
        "ou": { "type": "number" },
        "pt": { "type": "number" },
        "br": { "type": "number" }
      }
    },
    "igrejas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "nome"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "nome": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "titulo", "ordem"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
          "titulo": { "type": "string", "minLength": 1 },
          "categoria": {
            "type": "string",
            "description": "Nome da categoria (legado/derivado). A UI prefere `categoriaId`; este campo é mantido para retrocompatibilidade com eventos antigos."
          },
          "categoriaId": {
            "type": "string",
            "description": "Identificador da categoria em `categorias[]`. Quando ausente, é inferido a partir de `categoria`."
          },
          "tipo": {
            "type": "string",
            "enum": ["oral", "escrita"],
            "description": "Modalidade da prova: oral (esgrima, debate, etc.) ou escrita. Quando ausente, inferido pelo título."
          },
          "ordem": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
